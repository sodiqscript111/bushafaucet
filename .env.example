# PostgreSQL (reuses bushabot docker-compose on port 5433)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/faucet?sslmode=disable

# Redis (reuses bushabot docker-compose on port 6380)
REDIS_ADDR=127.0.0.1:6380

# Server
SERVER_PORT=8085

# Busha API (sandbox — pre-encoded Bearer token from dashboard)
BUSHA_API_KEY=your_base64_encoded_api_key_here
BUSHA_BASE_URL=https://api.staging.busha.so
BUSHA_PROFILE_ID=BUS_your_profile_id

# Faucet amounts per blockchain
FAUCET_AMOUNT_BTC=0.0001
FAUCET_AMOUNT_ETH=0.005
FAUCET_AMOUNT_USDT=5
FAUCET_AMOUNT_USDC=5
FAUCET_AMOUNT_BNB=0.01
